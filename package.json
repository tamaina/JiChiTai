{
  "name": "municipality-typing-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "pnpm build && vite preview",
    "deploy": "pnpm build && wrangler deploy",
    "geo:build": "node --max-old-space-size=4096 scripts/build-national-dataset.mjs",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run && vitest run --config vitest.worker.config.mts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:electron": "env -u ELECTRON_RUN_AS_NODE PLAYWRIGHT_USE_ELECTRON=1 xvfb-run -a playwright test --workers=1",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@lucide/vue": "^1.25.0",
    "hono": "^4.10.0",
    "valibot": "^1.1.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.0",
    "@cloudflare/vitest-pool-workers": "^0.12.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/compiler-sfc": "^3.5.40",
    "@vue/test-utils": "^2.4.0",
    "electron": "^43.2.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "fflate": "^0.8.3",
    "globals": "^16.0.0",
    "happy-dom": "^18.0.0",
    "polygon-clipping": "^0.15.7",
    "prettier": "^3.6.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "vue-eslint-parser": "^10.0.0",
    "vue-tsc": "^3.0.0",
    "wrangler": "^4.30.0"
  }
}
